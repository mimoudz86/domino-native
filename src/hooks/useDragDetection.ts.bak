import { useRef, useCallback, useEffect } from 'react';
import { PanResponder, type GestureResponderEvent } from 'react-native';
import type { Domino } from '../shared/models/Domino';
import { useActiveGameStore } from '../store/gameStoreContext';
import { calculateClosestSideRN } from '../utils/trainPositions';

type DraggableStatus = 'none' | 'left' | 'right' | 'both';

interface DragState {
  domino: Domino | null;
  draggableStatus: DraggableStatus;
  playerId: number | null;
  isDragging: boolean;
  startPos: { x: number; y: number } | null;
  currentPos: { x: number; y: number } | null;
}

const DRAG_THRESHOLD = 10; // px

/**
 * useDragDetection - Détecte JUSTE le drag, sans animation
 *
 * Logique PURE:
 * 1. onGranted → enregistre startPos
 * 2. onMove → met à jour currentPos, détecte si >10px (isDragging)
 * 3. onRelease → calcule le côté et place le domino
 *
 * Retourne: dragState + panHandlers pour attacher au View
 */
export function useDragDetection(domino: Domino | null, draggableStatus: DraggableStatus, playerId: number | null) {
  const { playDomino, turnState } = useActiveGameStore();

  // ✅ Utiliser useRef pour les valeurs actuelles (persistant à travers les re-renders)
  const currentValuesRef = useRef({ domino, draggableStatus, playerId });

  // ✅ Mettre à jour les refs quand les props changent (mais PanResponder reste stable)
  useEffect(() => {
    currentValuesRef.current = { domino, draggableStatus, playerId };
  }, [domino, draggableStatus, playerId]);

  const dragState = useRef<DragState>({
    domino: null,
    draggableStatus: 'none',
    playerId: null,
    isDragging: false,
    startPos: null,
    currentPos: null,
  });

  const totalSlots = turnState?.board?.trainOnBoard?.length ?? 0;

  // Handler: Début du drag
  const handleGranted = useCallback((e: GestureResponderEvent) => {
    const { domino: currentDomino, draggableStatus: currentStatus, playerId: currentPlayerId } = currentValuesRef.current;

    console.log(`[DRAG-GRANTED] Called - domino=${currentDomino?.left}|${currentDomino?.right}, status=${currentStatus}, playerId=${currentPlayerId}`);

    if (!currentDomino || currentStatus === 'none' || !currentPlayerId) {
      console.log(`[DRAG-GRANTED] ❌ Rejected - domino=${!!currentDomino}, status=${currentStatus}, playerId=${currentPlayerId}`);
      return;
    }

    const { pageX, pageY } = e.nativeEvent;
    dragState.current.domino = currentDomino;
    dragState.current.draggableStatus = currentStatus;
    dragState.current.playerId = currentPlayerId;
    dragState.current.startPos = { x: pageX, y: pageY };
    dragState.current.currentPos = { x: pageX, y: pageY };
    dragState.current.isDragging = false;

    console.log(`[DRAG-GRANTED] ✅ Started at (${pageX}, ${pageY})`);
  }, []);

  // Handler: Mouvement pendant le drag
  const handleMove = useCallback((e: GestureResponderEvent) => {
    if (!dragState.current.startPos) return;

    const { pageX, pageY } = e.nativeEvent;
    const { startPos } = dragState.current;

    const distance = Math.hypot(pageX - startPos.x, pageY - startPos.y);

    // Détecte le franchissement du seuil (>10px = c'est un drag)
    if (distance > DRAG_THRESHOLD && !dragState.current.isDragging) {
      dragState.current.isDragging = true;
      console.log(`[DRAG] Dragging started (distance=${distance.toFixed(1)}px)`);
    }

    // Mettre à jour la position courante
    dragState.current.currentPos = { x: pageX, y: pageY };
  }, []);

  // Handler: Relâchement du drag
  const handleRelease = useCallback(() => {
    if (!dragState.current.startPos || !dragState.current.domino) {
      console.log(`[DRAG] Release: invalid state`);
      resetDrag();
      return;
    }

    const { isDragging, domino: dragDomino, draggableStatus: dragStatus, playerId: dragPlayerId, currentPos } = dragState.current;

    // CAS 1: Clic simple (pas de drag)
    if (!isDragging) {
      console.log(`[DRAG] Simple click - no placement`);
      resetDrag();
      return;
    }

    // CAS 2: Drag complet - Placement du domino
    if (currentPos && totalSlots > 0) {
      console.log(`[DRAG] Dragging complete - totalSlots=${totalSlots}, pos=(${currentPos.x}, ${currentPos.y})`);
      const side = calculateClosestSideRN(totalSlots, currentPos.x, currentPos.y);
      const finalSide = dragStatus === 'both' ? side : (dragStatus as 'left' | 'right');

      console.log(`[DRAG] ✅ Placement at (${currentPos.x}, ${currentPos.y}) → side=${finalSide}`);

      // PLACEMENT IMMÉDIAT (logique pure, sans animation)
      playDomino(dragDomino, finalSide, false);
    } else {
      console.log(`[DRAG] ❌ Cannot place: currentPos=${currentPos}, totalSlots=${totalSlots}`);
    }

    resetDrag();
  }, [playDomino, totalSlots, currentValuesRef]);

  // Reset l'état du drag
  const resetDrag = useCallback(() => {
    dragState.current = {
      domino: null,
      draggableStatus: 'none',
      playerId: null,
      isDragging: false,
      startPos: null,
      currentPos: null,
    };
  }, []);

  // PanResponder pour capturer les gestes
  const panResponder = useRef(
    PanResponder.create({
      onStartShouldSetPanResponder: () => draggableStatus !== 'none',
      onMoveShouldSetPanResponder: () => draggableStatus !== 'none',
      onPanResponderGrant: handleGranted,
      onPanResponderMove: handleMove,
      onPanResponderRelease: handleRelease,
      onPanResponderTerminate: handleRelease,
    })
  ).current;

  return {
    // State
    isDragging: dragState.current.isDragging,
    startPos: dragState.current.startPos,
    currentPos: dragState.current.currentPos,

    // Handlers à attacher au View
    panHandlers: panResponder.panHandlers,
  };
}
